# 楽天商品監視システム 本番環境設定
# /etc/rakuten_monitor.env へコピーして使用

# データベース設定
DATABASE_URL=sqlite:///rakuten_monitor.db

# Discord Webhook URL (本番用に設定)
DISCORD_WEBHOOK_URL=

# Discord アラートチャンネル (エラー通知用)
DISCORD_ALERT_WEBHOOK_URL=

# 楽天商品ページ設定
LIST_URL=https://item.rakuten.co.jp/auc-p-entamestore/c/0000000174/?s=4
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) Gecko

# Prometheus メトリクス設定
METRICS_PORT=9100

# ログ設定
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5