# 楽天商品監視システム 環境設定テンプレート
# 実際に使用する際は、このファイルを .env にコピーして値を設定してください

# データベース設定
DATABASE_URL=sqlite:///rakuten_monitor.db
# PostgreSQL使用時の例: DATABASE_URL=postgresql://user:password@localhost:5432/rakuten_monitor

# Discord Webhook URL (必須: 本番運用時は必ず設定)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# 楽天商品ページ設定
LIST_URL=https://item.rakuten.co.jp/auc-p-entamestore/c/0000000174/?s=4
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) Gecko