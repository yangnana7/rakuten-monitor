# 楽天商品監視システム 環境変数設定例
# .env として保存して使用してください

# データベース設定
DATABASE_URL=sqlite:///rakuten_monitor.db
# PostgreSQL使用時の例:
# DATABASE_URL=postgresql://rakuten_user:rakuten_pass@localhost:5432/rakuten_monitor

# Discord Webhook URL (本番用に設定)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord アラートチャンネル (エラー通知用)
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ALERT_WEBHOOK_ID/YOUR_ALERT_WEBHOOK_TOKEN

# 楽天商品ページ設定
LIST_URL=https://item.rakuten.co.jp/auc-p-entamestore/c/0000000174/?s=4
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# Prometheus メトリクス設定
METRICS_PORT=9100

# ログ設定
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# システム設定
ENVIRONMENT=production
